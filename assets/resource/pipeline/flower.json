{
    "$schema": "../../../deps/tools/pipeline.schema.json",
    "FlowerLaugh": {
        "doc": "入口：循环点击大笑，8秒间隔，待机自动点掉",
        "next": ["FlowerLaugh_Click", "[JumpBack]Flower_HandleIdle"],
        "timeout": -1
    },
    "FlowerLaugh_Click": {
        "doc": "点击大笑按钮",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "flower/laugh",
                "roi": [368, 533, 442, 83]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 8000,
        "next": ["FlowerLaugh_Click", "[JumpBack]Flower_HandleIdle"],
        "timeout": -1
    },

    "FlowerBow": {
        "doc": "入口：循环点击鞠躬，15秒间隔，待机自动点掉",
        "next": ["FlowerBow_Click", "[JumpBack]Flower_HandleIdle"],
        "timeout": -1
    },
    "FlowerBow_Click": {
        "doc": "点击鞠躬按钮",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "flower/bow",
                "roi": [368, 533, 442, 83]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 15000,
        "next": ["FlowerBow_Click", "[JumpBack]Flower_HandleIdle"],
        "timeout": -1
    },

    "Flower_HandleIdle": {
        "doc": "检测到待机画面，点击消除",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "common/idle_screen.png",
                "roi": [584, 340, 58, 63]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 500
    },

    "FlowerReplay": {
        "doc": "入口：循环点击播放留影（观赏按钮），待机自动点掉",
        "next": ["FlowerReplay_Play", "[JumpBack]Flower_HandleIdle"],
        "timeout": -1
    },
    "FlowerReplay_Play": {
        "doc": "点击观赏/播放留影按钮",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "flower/replay",
                "roi": [704, 316, 263, 73]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 8500,
        "next": ["FlowerReplay_Play", "[JumpBack]Flower_HandleIdle"],
        "timeout": -1
    }
}
