{
    "interface_version": 2,
    "name": "MAARoco",
    "label": "MAA洛克王国",
    "description": "洛克王国手游自动化助手，基于 MaaFramework 开发。",
    "contact": "GitHub: https://github.com/X-Zero-L/MAARoco",
    "license": "MIT",
    "welcome": "欢迎使用 MAA洛克王国助手！\n\n首次使用请先连接设备，然后选择需要执行的任务。",
    "version": "0.1.0",
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 720
        }
    ],
    "resource": [
        {
            "name": "默认",
            "path": [
                "resource"
            ]
        }
    ],
    "task": [
        {
            "name": "启动游戏",
            "entry": "StartApp",
            "description": "启动洛克王国并等待进入主界面"
        },
        {
            "name": "每日签到",
            "entry": "DailySignIn",
            "description": "完成每日签到领取奖励"
        },
        {
            "name": "每日任务",
            "entry": "DailyQuest",
            "description": "自动完成每日任务"
        },
        {
            "name": "宠物练级",
            "entry": "PetLeveling",
            "description": "自动战斗练级宠物",
            "option": [
                "练级次数"
            ]
        },
        {
            "name": "领取邮件",
            "entry": "CollectMail",
            "description": "一键领取所有邮件奖励"
        },
        {
            "name": "产花·表情动作",
            "entry": "Flower",
            "description": "循环点击表情（优先大笑，无则鞠躬），请先打开表情面板"
        },
        {
            "name": "产花·播放留影",
            "entry": "FlowerReplay",
            "default_check": true,
            "description": "循环点击观赏/播放留影按钮，请先保证留影按钮出现"
        },
        {
            "name": "关闭游戏",
            "entry": "StopApp",
            "description": "关闭洛克王国"
        }
    ],
    "option": {
        "练级次数": {
            "type": "select",
            "label": "练级次数",
            "cases": [
                {
                    "name": "10次",
                    "pipeline_override": {
                        "PetBattleLoop": {
                            "max_hit": 10
                        }
                    }
                },
                {
                    "name": "20次",
                    "pipeline_override": {
                        "PetBattleLoop": {
                            "max_hit": 20
                        }
                    }
                },
                {
                    "name": "50次",
                    "pipeline_override": {
                        "PetBattleLoop": {
                            "max_hit": 50
                        }
                    }
                },
                {
                    "name": "无限",
                    "pipeline_override": {}
                }
            ],
            "default_case": "20次"
        }
    }
}
